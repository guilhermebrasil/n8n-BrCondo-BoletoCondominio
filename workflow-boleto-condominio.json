            }
          }
        }
      },
      "id": "806e6586-425f-4ad3-8066-664c38cdacc5",
      "name": "Acessar Página do Boleto",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        240,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "// Extrai o link direto do PDF da página do boleto\nconst html = $input.first().json.data;\nconst billUuid = $('Extrair Link do Boleto').first().json.billUuid;\nconst subject = $('Extrair Link do Boleto').first().json.subject;\n\n// Procura o link do PDF na página\n// Formato: https://ssl.brcondos.com.br/BillPDF/{uuid}/{nome-do-arquivo}\nconst pdfRegex = /https:\\/\\/ssl\\.brcondos\\.com\\.br\\/BillPDF\\/[^\"'\\s]+/i;\nconst match = html.match(pdfRegex);\n\nlet pdfUrl;\n\nif (match) {\n  // Limpa possíveis caracteres HTML no final\n  pdfUrl = match[0].replace(/[\"'<>]/g, '');\n} else {\n  // Fallback: constrói a URL do PDF a partir do UUID\n  pdfUrl = `https://ssl.brcondos.com.br/BillPDF/${billUuid}/Boleto`;\n}\n\nreturn [{\n  json: {\n    pdfUrl: pdfUrl,\n    billUuid: billUuid,\n    subject: subject\n  }\n}];"
      },
