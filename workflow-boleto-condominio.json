      "id": "ad540bd6-0148-4686-92b7-9b27a34a2506",
      "name": "Tem Email?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        -240,
        112
      ]
    },
    {
      "parameters": {
        "jsCode": "// Processa cada email encontrado\nconst results = [];\n\nfor (const item of $input.all()) {\n  const subject = item.json.subject || '';\n  let body = '';\n\n  // Tenta obter o corpo do email em texto ou HTML\n  if (item.json.textPlain) {\n    body = item.json.textPlain;\n  } else if (item.json.textHtml) {\n    body = item.json.textHtml;\n  } else if (item.json.payload && item.json.payload.body && item.json.payload.body.data) {\n    // Decodifica base64url\n    const base64 = item.json.payload.body.data.replace(/-/g, '+').replace(/_/g, '/');\n    body = Buffer.from(base64, 'base64').toString('utf-8');\n  }\n\n  // Extrai o link do Bill (formato: https://ssl.brcondos.com.br/Bill/{uuid})\n  const billRegex = /https:\\/\\/ssl\\.brcondos\\.com\\.br\\/Bill\\/([a-f0-9\\-]{36})/i;\n  const match = body.match(billRegex);\n\n  if (match) {\n    const billUuid = match[1];\n    const billUrl = `https://ssl.brcondos.com.br/Bill/${billUuid}`;\n\n    results.push({\n      json: {\n        subject: subject,\n        billUuid: billUuid,\n        billUrl: billUrl,\n        messageId: item.json.id || item.json.messageId || ''\n      }\n    });\n  }\n}\n\nif (results.length === 0) {\n  throw new Error('Nenhum link de boleto encontrado nos emails.');\n}\n\nreturn results;"
      },
      "id": "2118ac3c-963f-459b-82de-12322116bebd",
      "name": "Extrair Link do Boleto",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
